{
  "name": "git-worktrees",
  "version": "1.0.0",
  "description": "Interactive CLI for managing git worktrees",
  "type": "module",
  "bin": {
    "git-worktrees": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
